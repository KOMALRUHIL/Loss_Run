# ==============================================================================
# STANDARD AZURE OPENAI CONNECTION CONFIGURATION
# ==============================================================================
# Fill these in if you want all models to use a single default Azure OpenAI instance.
# The code will fall back to these default values if specific model variables are empty.
AZURE_OPENAI_ENDPOINT=https://your-default-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your_default_api_key_here

# ==============================================================================
# GPT-5.2 CONFIGURATION (EXCLUSIVE MODEL)
# ==============================================================================
GPT_5_2_ENDPOINT=https://your-gpt5-2-resource.openai.azure.com/
GPT_5_2_API_KEY=your_gpt5_2_api_key_here
